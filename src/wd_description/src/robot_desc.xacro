        <material name="red"/>
        </visual>

        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/battery_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0.0115" rpy="0 0 0"/>
            <mass value="0.178"/>
            <inertia 
            ixx="1.71E-04" ixy="0" ixz="0"
            iyy="2.50E-05" iyz="0"
            izz="1.81E-04"/>
        </inertial> 
    </link>

    <joint name="battery_joint" type="fixed">
        <parent link="base_link"/>
        <child link="battery_link"/>
        <origin xyz="0.163 0 0.011"/>
    </joint>

    <!-- ========= PCB ========= -->

