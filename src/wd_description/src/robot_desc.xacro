        </geometry>
        </collision>

        <!-- done -->
        <inertial>
            <origin xyz="0 0 0.0275" rpy="0 0 0"/>
            <mass value="0.187"/>
            <inertia 
            ixx="1.23E-04" ixy="0" ixz="0"
            iyy="2.03E-04" iyz="0"
            izz="2.32E-04"/>
