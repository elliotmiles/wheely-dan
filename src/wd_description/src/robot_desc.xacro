        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/wheel_left_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0.003 0" rpy="0 0 0"/>
            <mass value="0.046"/>
            <inertia 
            ixx="1.45E-05" ixy="0" ixz="0"
            iyy="2.43E-05" iyz="0"
            izz="1.45E-05"/>
        </inertial>
    </link>

    <joint name="wheel_left_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_left_link"/>
        <origin xyz="0 0.098 0.0145"/>
        <axis xyz="0 1 0"/>
        <limit effort="0.05" velocity="10.0"/>
    </joint>

    <!-- ========= WHEEL R ========= -->

