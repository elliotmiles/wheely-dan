        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/driver_left_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.02"/>
            <inertia 
            ixx="6.24E-06" ixy="0" ixz="0"
            iyy="1.86E-06" iyz="0"
            izz="8.02E-06"/>
        </inertial>
    </link>

    <joint name="driver_left_joint" type="fixed">
