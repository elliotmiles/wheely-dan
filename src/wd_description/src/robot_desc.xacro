<?xml version="1.0"?>
<robot name="wheely_dan" xmlns:xacro="http://www.ros.org/wiki/xacro">
    
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="red">
        <color rgba="0.3 0 0 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0 0 0.05 1"/>
    </material>

    <material name="grey">
        <color rgba="0.4 0.4 0.4 1"/>
    </material>

    <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1"/>
    </material>

    <material name="green">
        <color rgba="0.125 0.3 0 1"/>
    </material>

    <!-- ========= BASE ========= -->

    <link name="base_link">

    </link>

    <!-- ========= CHASSIS ========= -->

    <link name="chassis_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/chassis_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey"/>
        </visual>

        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/chassis_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <inertial>
            <origin xyz="0.097 0.003 0.029" rpy="0 0 0"/>
            <mass value="1.227"/>
            <inertia 
            ixx="3.86E-03" ixy="0" ixz="0"
            iyy="6.37E-03" iyz="0"
            izz="8.57E-03"/>
        </inertial>
    </link>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="-0.035 0 0"/>
    </joint>  


    <!-- ========= JETSON ========= -->

    <link name="jetson_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/jetson_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="dark_grey"/>
        </visual>

        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/jetson_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0.005" rpy="0 0 0"/>
            <mass value="0.182"/>
            <inertia 
            ixx="1.79E-04" ixy="0" ixz="0"
            iyy="1.43E-04" iyz="0"
            izz="2.85E-04"/>
        </inertial>     
    </link>

    <joint name="jetson_joint" type="fixed">
        <parent link="base_link"/>
        <child link="jetson_link"/>
        <origin xyz="0.12625 0 0.057"/>
    </joint>

    
    <!-- ========= BATTERY ========= -->

