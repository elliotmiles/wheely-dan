    <!-- ========= GAZEBO SETTINGS ========= -->

    <gazebo reference="caster_wheel_left_link">
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>

    <gazebo reference="caster_wheel_right_link">
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>

</robot>