<?xml version="1.0" ?>
<sdf version="1.7">
  <world name="default">

    <!-- Physics -->
    <gravity>0 0 -9.8</gravity>
    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Ground -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </visual>
      </link>
    </model>

    <!-- Light -->
    <light name="sun" type="directional">
      <direction>-0.5 0.5 -1</direction>
    </light>

    <!-- Outer walls -->
    <model name="walls">
      <static>true</static>

      <!-- Wall 1 -->
      <link name="wall1">
        <pose>0 5 1 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>10 0.2 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>10 0.2 2</size></box></geometry>
        </visual>
      </link>

      <!-- Wall 2 -->
      <link name="wall2">
        <pose>0 -5 1 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>10 0.2 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>10 0.2 2</size></box></geometry>
        </visual>
      </link>

      <!-- Wall 3 -->
      <link name="wall3">
        <pose>5 0 1 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>0.2 10 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.2 10 2</size></box></geometry>
        </visual>
      </link>

      <!-- Wall 4 -->
      <link name="wall4">
        <pose>-5 0 1 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>0.2 10 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.2 10 2</size></box></geometry>
        </visual>
      </link>
    </model>

    <!-- Internal walls (rooms) -->
    <model name="internal_walls">
      <static>true</static>

      <link name="wallA">
        <pose>0 2 1 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>6 0.2 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>6 0.2 2</size></box></geometry>
        </visual>
      </link>

      <link name="wallB">
        <pose>-2 -1 1 0 0 1.57</pose>
        <collision name="col">
          <geometry><box><size>6 0.2 2</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>6 0.2 2</size></box></geometry>
        </visual>
      </link>
    </model>

    <!-- Obstacles -->
    <model name="box1">
      <static>true</static>
      <pose>2 2 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>1 1 1</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>1 1 1</size></box></geometry>
        </visual>
      </link>
    </model>

    <model name="box2">
      <static>true</static>
      <pose>-2 3 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>1 1 1</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>1 1 1</size></box></geometry>
        </visual>
      </link>
    </model>

  </world>
</sdf>